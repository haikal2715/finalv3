# =============================================================
# ZENITH BOT — Environment Variables
# Salin file ini menjadi .env dan isi semua nilai
# JANGAN commit file .env ke repository
# =============================================================

# --- Telegram ---
BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- PostgreSQL VPS (Cache) ---
VPS_DB_HOST=localhost
VPS_DB_PORT=5432
VPS_DB_NAME=zenith_cache
VPS_DB_USER=zenith_user
VPS_DB_PASS=your_vps_db_password

# --- AI Providers ---
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key
CEREBRAS_API_KEY=your_cerebras_key
GEMINI_API_KEY=your_gemini_key
LLM7_API_KEY=your_llm7_key
SILICONFLOW_API_KEY=your_siliconflow_key

# --- Cohere (RAG Embedding) ---
COHERE_API_KEY=your_cohere_key

# --- News ---
GNEWS_API_KEY=your_gnews_key

# --- Payment ---
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# --- Auth ---
JWT_SECRET_KEY=your_very_long_random_jwt_secret_minimum_32_chars
JWT_ALGORITHM=HS256

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://zenithidx.koyeb.app/auth/google/callback

# --- Web Server ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
BASE_URL=https://zenithidx.koyeb.app

# --- App Settings ---
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=Asia/Jakarta
